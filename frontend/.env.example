# ─────────────────────────────────────────────────────────────────────────────
# frontend/.env.example
#
# Para desarrollo local: no necesitás hacer nada.
#   Vite ya tiene un proxy configurado en vite.config.js que redirige
#   /api → http://localhost:3001 automáticamente.
#
# Para producción (GitHub Pages / Vercel / Netlify):
#   Copiá como .env.production y poné la URL de tu backend en Railway:
#   cp .env.example .env.production
# ─────────────────────────────────────────────────────────────────────────────

# URL pública del backend en Railway (sin slash final).
# En desarrollo local dejá esto vacío o no crees el archivo .env.local.
# Ejemplo: VITE_API_URL=https://studio-pro-backend-production.up.railway.app
VITE_API_URL=
