# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
# Copiá como .env para desarrollo local: cp .env.example .env
# NUNCA commitees .env al repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Puerto ────────────────────────────────────────────────────────────────────
# Railway sobreescribe PORT automáticamente. En local usá 3000 o 3001.
PORT=3000

# ── Base de datos ─────────────────────────────────────────────────────────────
#
# PRODUCCIÓN (Railway):
#   DATABASE_URL la inyecta Railway automáticamente al linkear el plugin de Postgres.
#   NO la seteás a mano. Solo asegurate de que el servicio Postgres esté linkeado.
#   En producción, si DATABASE_URL no existe, el servidor falla con error claro.
#
DATABASE_URL=

#
# DESARROLLO LOCAL:
#   Si DATABASE_URL está vacía, el servidor usa las variables sueltas de abajo.
#   Completá con tus credenciales locales de Postgres.
#
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password_local
PGDATABASE=studio_pro

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dominio del frontend. En prod: tu URL de GitHub Pages o Railway frontend.
# Vacío = acepta cualquier origen (útil en desarrollo).
FRONTEND_URL=
# Ejemplo: FRONTEND_URL=https://tu-usuario.github.io
