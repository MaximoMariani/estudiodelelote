# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
# Copiá este archivo como .env para desarrollo local:
#   cp .env.example .env
# NUNCA commitees .env al repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Puerto del servidor ───────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente. En local podés usar 3001 o lo que quieras.
PORT=3001

# ── Base de datos ─────────────────────────────────────────────────────────────
#
# OPCIÓN A — Railway (producción):
#   Railway setea DATABASE_URL automáticamente al agregar el plugin de PostgreSQL.
#   No necesitás hacer nada. Dejalo en blanco acá.
DATABASE_URL=

#
# OPCIÓN B — Desarrollo local con variables sueltas:
#   Usá estas si no tenés DATABASE_URL. El servidor las combina internamente.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_password_local
PGDATABASE=studio_pro

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend. En Railway ponés tu dominio de GitHub Pages o Railway.
# En local podés dejarlo vacío (acepta cualquier origen).
FRONTEND_URL=
# Ejemplo producción: FRONTEND_URL=https://tu-usuario.github.io
